# ── Django Backend ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=False
TEST_MODE=False
ALLOWED_HOSTS=your-backend-domain.runflare.run
DATABASE_URL=postgresql://user:password@host:5432/dbname
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.runflare.run
CSRF_TRUSTED_ORIGINS=https://your-backend-domain.runflare.run,https://your-frontend-domain.runflare.run
FRONTEND_BASE_URL=https://your-frontend-domain.runflare.run
PAYMENT_CALLBACK_BASE_URL=https://your-backend-domain.runflare.run/api/payment/callback
PAYMENT_SANDBOX=True
ZARINPAL_MERCHANT_CODE=sandbox
KAVENEGAR_API_KEY=
SMS_SENDER=
OTP_EXPIRY_MINUTES=2
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Next.js Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-backend-domain.runflare.run
NEXT_PUBLIC_SITE_URL=https://your-frontend-domain.runflare.run

# ── PostgreSQL (Docker Compose local dev) ──────────────────────
POSTGRES_DB=shop
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop
