# ============================================================
#  Environment Variables — Runflare Production
#  Set these in Runflare Dashboard → Environment Variables
# ============================================================

# ── Database (provided by Runflare Postgres addon) ──────────
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=generate-a-random-50-char-key
DEBUG=False
USE_SSL=True
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Hosts & CORS ───────────────────────────────────────────
ALLOWED_HOSTS=farzamback-farazmgps.runflare.run
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://farazmgps.runflare.run
CSRF_TRUSTED_ORIGINS=https://farzamback-farazmgps.runflare.run,https://farazmgps.runflare.run

# ── URLs ────────────────────────────────────────────────────
FRONTEND_BASE_URL=https://farazmgps.runflare.run
PAYMENT_CALLBACK_BASE_URL=https://farzamback-farazmgps.runflare.run/api/payment/callback
NEXT_PUBLIC_API_URL=https://farzamback-farazmgps.runflare.run
NEXT_PUBLIC_SITE_URL=https://farazmgps.runflare.run

# ── Payment ─────────────────────────────────────────────────
PAYMENT_SANDBOX=True
ZARINPAL_MERCHANT_CODE=sandbox

# ── OTP ─────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=2

# ── SMS (optional) ──────────────────────────────────────────
KAVENEGAR_API_KEY=your-key
SMS_SENDER=your-sender


# ============================================================
#  Self-Hosted Server (Docker Compose)
#  Copy .env.server → .env.server.local, edit, then:
#    docker compose --env-file .env.server.local up --build -d
# ============================================================
#
# SERVER_DOMAIN=example.com
# NEXT_PUBLIC_API_URL=http://${SERVER_DOMAIN}:8000
# NEXT_PUBLIC_SITE_URL=http://${SERVER_DOMAIN}:3000
# FRONTEND_BASE_URL=http://${SERVER_DOMAIN}:3000
# PAYMENT_CALLBACK_BASE_URL=http://${SERVER_DOMAIN}:8000/api/payment/callback
# ALLOWED_HOSTS=${SERVER_DOMAIN},localhost,127.0.0.1,backend
# CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=http://${SERVER_DOMAIN}:3000
# CSRF_TRUSTED_ORIGINS=http://${SERVER_DOMAIN}:3000,http://${SERVER_DOMAIN}:8000
