# ── Django Backend ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=False
TEST_MODE=False
ALLOWED_HOSTS=*
DATABASE_URL=postgres://shop:shop@db:5432/shop
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app
FRONTEND_BASE_URL=https://your-frontend.up.railway.app
PAYMENT_CALLBACK_BASE_URL=https://your-backend.up.railway.app/api/payment/callback
PAYMENT_SANDBOX=True
ZARINPAL_MERCHANT_CODE=sandbox
KAVENEGAR_API_KEY=
SMS_SENDER=
OTP_EXPIRY_MINUTES=2
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Next.js Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
NEXT_PUBLIC_SITE_URL=https://your-frontend.up.railway.app

# ── PostgreSQL (Railway provides these automatically) ──────────
POSTGRES_DB=shop
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop
