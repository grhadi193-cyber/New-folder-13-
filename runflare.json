{
  "project": "ati-farzam",
  "services": [
    {
      "name": "backend",
      "type": "django",
      "path": "./backend",
      "build": {
        "command": "pip install -r requirements.txt"
      },
      "start": {
        "command": "/entrypoint.sh"
      },
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.production"
      },
      "ports": [8000]
    },
    {
      "name": "frontend",
      "type": "nextjs",
      "path": "./frontend",
      "build": {
        "command": "npm install && npm run build"
      },
      "start": {
        "command": "npm start"
      },
      "ports": [3000]
    }
  ],
  "databases": [
    {
      "name": "postgres",
      "type": "postgres",
      "version": "16"
    }
  ]
}
